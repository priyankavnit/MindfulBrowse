{
  "name": "@mindful-browse/infrastructure",
  "version": "1.0.0",
  "description": "AWS CDK infrastructure for Mindful Browse MVP",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy": "cdk deploy --all",
    "deploy:staging": "cdk deploy --all --context environment=staging",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "destroy": "cdk destroy --all"
  },
  "keywords": [
    "mindful-browse",
    "infrastructure",
    "aws-cdk"
  ],
  "author": "Mindful Browse Team",
  "license": "MIT",
  "dependencies": {
    "aws-cdk-lib": "^2.100.0",
    "constructs": "^10.0.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "aws-cdk": "^2.100.0",
    "typescript": "^5.0.0"
  }
}
