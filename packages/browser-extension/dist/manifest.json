{
  "manifest_version": 3,
  "name": "Mindful Browse",
  "version": "1.0.0",
  "description": "Track your browsing patterns and develop healthier digital habits",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Mindful Browse",
    "default_popup": "popup.html"
  }
}
